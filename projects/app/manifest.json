{
  "manifest_version": 3,
  "name": "TabMagnet-Solo",
  "version": "0.1.0",
  "description": "Magnetically aggregate specific tabs into the current window and maintain singleton groups.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "sidePanel",
    "clipboardRead"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
